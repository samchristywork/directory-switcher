# directory-switcher keybindings
# Copy to ~/.config/directory-switcher/config to use.
# Each value must be a single character. Lines starting with # are ignored.

quit = q
move_down = j
move_up = k
go_first = g
go_last = G
go_home = ~
navigate_in = l
navigate_out = h
toggle_hidden = .
cycle_sort = s
open_editor = o
bookmark_add = m
bookmark_remove = M
bookmark_jump = '
bookmark_list = B
filter = /
help = ?
preview_up = [
preview_down = ]
